NODE_ENV=development

# HTTP server
PORT=4000

# Internal authentication
INTERNAL_API_KEY=change-me-to-a-long-random-string

# ULIP credentials and endpoints
# Replace with your actual production credentials; do not commit real values.
ULIP_USERNAME=your-ulip-username
ULIP_PASSWORD=your-ulip-password
ULIP_BASE_URL=https://www.ulip.dpiit.gov.in/ulip/v1.0.0
ULIP_LOGIN_URL=https://www.ulip.dpiit.gov.in/ulip/v1.0.0/user/login

# ULIP HTTP behaviour
ULIP_TIMEOUT_MS=10000
ULIP_RETRY_COUNT=2
ULIP_TIMEOUT_LOGIN_MS=10000
ULIP_TIMEOUT_VAHAN_MS=12000
ULIP_TIMEOUT_SARATHI_MS=10000
ULIP_TIMEOUT_FASTAG_MS=15000
ULIP_TIMEOUT_ECHALLAN_MS=12000
ULIP_TIMEOUT_EWAYBILL_MS=12000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Optional circuit breaker
ULIP_CIRCUIT_BREAKER_ENABLED=false
ULIP_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
ULIP_CIRCUIT_BREAKER_COOLDOWN_MS=30000

# Optional alerting webhook (Slack/Teams/custom)
ULIP_ALERT_WEBHOOK_URL=
ULIP_ALERT_COOLDOWN_MS=300000

# Logging
LOG_LEVEL=info

